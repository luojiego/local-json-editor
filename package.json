{
  "name": "json-online-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:monaco-assets": "node scripts/sync-monaco-assets.mjs",
    "dev": "pnpm sync:monaco-assets && vite --host",
    "build": "pnpm sync:monaco-assets && pnpm typecheck && vite build",
    "preview": "pnpm sync:monaco-assets && vite preview",
    "typecheck": "tsc --noEmit",
    "package:qa-win10": "pnpm build && node scripts/package-qa-win10.mjs"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "fuse.js": "^7.1.0",
    "jsonc-parser": "^3.3.1",
    "lucide-react": "^0.511.0",
    "monaco-editor": "^0.54.0",
    "pinyin-pro": "^3.27.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.0.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.0"
  },
  "packageManager": "pnpm@10.14.0"
}
